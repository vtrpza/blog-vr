---
import '../styles/global.css';
import SiteHeader from '../components/SiteHeader.astro';
import { OFFICES, REQUIRED_TRACKING_EVENTS, SOCIAL_LINKS } from '../lib/taxonomy';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  pageType?: string;
  cluster?: string;
  intent?: string;
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  pageType = 'page',
  cluster,
  intent,
  noindex = false,
  jsonLd = [],
} = Astro.props;

const canonicalUrl = new URL(canonicalPath, Astro.site ?? 'https://blog.vradvogados.com.br').toString();
const jsonLdItems = Array.isArray(jsonLd) ? jsonLd : [jsonLd];
const viewEvent = pageType === 'home' ? 'page_view' : `${pageType}_view`;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="theme-color" content="#05070a" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/assets/favicon/favicon-192x192.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/favicon/apple-touch-icon.png" />
    <meta name="msapplication-TileColor" content="#05070a" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <script is:inline define:vars={{ pageType, cluster, intent, viewEvent, requiredEvents: REQUIRED_TRACKING_EVENTS }}>
      window.dataLayer = window.dataLayer || [];
      window.__BLOG_VR_REQUIRED_EVENTS__ = requiredEvents;
      window.dataLayer.push({ event: viewEvent, page_type: pageType, cluster, intent });
    </script>
    {jsonLdItems.map((item) => <script is:inline type="application/ld+json" set:html={JSON.stringify(item)} />)}
  </head>
  <body data-page-type={pageType} data-cluster={cluster} data-intent={intent}>
    <SiteHeader />
    <main id="conteudo">
      <slot />
    </main>
    <footer class="border-t border-[rgba(201,168,108,0.12)] bg-navy-900/40 py-14 text-sm text-stone-500">
      <div class="mx-auto flex max-w-6xl flex-col gap-6 px-5 md:flex-row md:items-center md:justify-between">
        <div>
          <p class="font-serif text-lg font-semibold text-cream-50">VR Advogados</p>
          <p class="mt-1">© {new Date().getFullYear()} Conteúdo informativo.</p>
        </div>
        <nav class="flex flex-wrap gap-5" aria-label="Rodapé">
          <a class="transition hover:text-cream-50" href="/sobre-o-blog/">Sobre o blog</a>
          <a class="transition hover:text-cream-50" href="/privacidade/">Privacidade</a>
          <a class="transition hover:text-cream-50" href="/diagnostico-inicial/">Diagnóstico inicial</a>
        </nav>
      </div>
      <!-- Filiais -->
      <div class="mx-auto mt-10 max-w-6xl px-5">
        <p class="mb-5 text-xs font-bold uppercase tracking-[0.25em] text-bronze-300/70">Nossas filiais</p>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {OFFICES.map((office) => (
            <div class="rounded-lg border border-[rgba(201,168,108,0.08)] bg-navy-950/50 p-4">
              <p class="font-sans text-xs font-semibold uppercase tracking-wider text-cream-50">
                {office.city} &mdash; {office.state}
              </p>
              <p class="mt-1.5 text-xs leading-relaxed text-stone-400">
                {office.address}
              </p>
            </div>
          ))}
        </div>
      </div>
      <!-- Redes sociais -->
      <div class="mx-auto mt-10 flex max-w-6xl items-center justify-center gap-6 px-5 md:justify-start">
        <span class="hidden text-[10px] font-bold uppercase tracking-[0.2em] text-stone-600 md:block">Siga a VR</span>
        <div class="flex items-center gap-4">
          <a href={SOCIAL_LINKS.instagram} target="_blank" rel="noopener noreferrer" class="flex h-9 w-9 items-center justify-center rounded-full border border-[rgba(201,168,108,0.15)] bg-navy-950/60 text-stone-500 transition hover:border-bronze-500/30 hover:text-bronze-400" aria-label="Instagram">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href={SOCIAL_LINKS.facebook} target="_blank" rel="noopener noreferrer" class="flex h-9 w-9 items-center justify-center rounded-full border border-[rgba(201,168,108,0.15)] bg-navy-950/60 text-stone-500 transition hover:border-bronze-500/30 hover:text-bronze-400" aria-label="Facebook">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener noreferrer" class="flex h-9 w-9 items-center justify-center rounded-full border border-[rgba(201,168,108,0.15)] bg-navy-950/60 text-stone-500 transition hover:border-bronze-500/30 hover:text-bronze-400" aria-label="LinkedIn">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href={SOCIAL_LINKS.youtube} target="_blank" rel="noopener noreferrer" class="flex h-9 w-9 items-center justify-center rounded-full border border-[rgba(201,168,108,0.15)] bg-navy-950/60 text-stone-500 transition hover:border-bronze-500/30 hover:text-bronze-400" aria-label="YouTube">
            <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>
    </footer>
    <script is:inline>
      (() => {
        const track = (event, payload = {}) => {
          window.dataLayer = window.dataLayer || [];
          window.dataLayer.push({ event, ...payload });
        };
        window.__blogVrTrack = track;

        const bind = () => {
          document.querySelectorAll('[data-track-cta]').forEach((element) => {
            if (element.dataset.boundCta === 'true') return;
            element.dataset.boundCta = 'true';
            element.addEventListener('click', () => {
              const payload = {
                page_type: element.dataset.pageType || document.body.dataset.pageType,
                cluster: element.dataset.cluster || document.body.dataset.cluster,
                intent: element.dataset.intent || document.body.dataset.intent,
                cta_type: element.dataset.ctaType,
                cta_position: element.dataset.ctaPosition,
                article_slug: element.dataset.articleSlug,
              };
              track('cta_click', payload);
              if (payload.cta_type === 'whatsapp') track('whatsapp_click', payload);
            });
          });

          const viewed = new WeakSet();
          const emitView = (element) => {
            if (viewed.has(element)) return;
            viewed.add(element);
            track('cta_view', {
              page_type: element.dataset.pageType || document.body.dataset.pageType,
              cluster: element.dataset.cluster || document.body.dataset.cluster,
              intent: element.dataset.intent || document.body.dataset.intent,
              cta_type: element.dataset.ctaType,
              cta_position: element.dataset.ctaPosition,
              article_slug: element.dataset.articleSlug,
            });
          };

          const ctas = [...document.querySelectorAll('[data-track-cta]')];
          if ('IntersectionObserver' in window) {
            const observer = new IntersectionObserver((entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) emitView(entry.target);
              });
            }, { threshold: 0.4 });
            ctas.forEach((cta) => observer.observe(cta));
          } else {
            ctas.forEach(emitView);
          }

          const thresholds = new Set([50, 75, 90]);
          const sent = new Set();
          window.addEventListener('scroll', () => {
            const max = document.documentElement.scrollHeight - window.innerHeight;
            if (max <= 0) return;
            const percentage = Math.round((window.scrollY / max) * 100);
            [...thresholds].forEach((threshold) => {
              if (percentage >= threshold && !sent.has(threshold)) {
                sent.add(threshold);
                track(`scroll_${threshold}`, { page_type: document.body.dataset.pageType, cluster: document.body.dataset.cluster });
              }
            });
          }, { passive: true });

          document.addEventListener('click', (event) => {
            const anchor = event.target.closest('a[href^="/"]');
            if (!anchor || anchor.hasAttribute('data-track-cta')) return;
            track('internal_link_click', {
              page_type: document.body.dataset.pageType,
              cluster: document.body.dataset.cluster,
              target_url: anchor.getAttribute('href'),
            });
          });
        };

        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', bind);
        else bind();
      })();
    </script>
  </body>
</html>
