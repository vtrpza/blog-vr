---
import type { Cluster } from '../lib/taxonomy';
import { getArticlesByCluster, getChecklistByRoute } from '../lib/taxonomy';

interface Props {
  cluster: Cluster;
}

const { cluster } = Astro.props;
const articles = getArticlesByCluster(cluster.slug);
const checklist = cluster.checklistRoute ? getChecklistByRoute(cluster.checklistRoute) : null;
const isUrgent = cluster.slug === 'busca-e-apreensao';
---

<article class={`group relative flex h-full flex-col overflow-hidden rounded-2xl border bg-white transition duration-300 hover:-translate-y-1.5 hover:shadow-2xl ${isUrgent ? 'border-red-500/20 shadow-red-500/5' : 'border-stone-200/70'}`}>
  {isUrgent && (
    <div class="absolute right-0 top-0 z-20 rounded-bl-xl bg-red-500 px-3 py-1 text-[10px] font-bold uppercase tracking-widest text-white">
      Urgente
    </div>
  )}

  <!-- Top accent gradient line -->
  <div class={`h-1 w-full ${isUrgent ? 'bg-gradient-to-r from-red-500 to-red-400' : 'bg-gradient-to-r from-bronze-500 via-gold-300 to-bronze-400'}`}></div>

  <div class="flex flex-1 flex-col p-7">

    <!-- Header: tagline + title (fixed height) -->
    <div>
      <p class={`text-xs font-bold uppercase tracking-[0.15em] ${isUrgent ? 'text-red-500' : 'text-bronze-500'}`}>
        {cluster.tagline}
      </p>

      <h3 class="mt-3 font-serif text-2xl font-bold leading-tight tracking-tight text-navy-950">
        <a class="after:absolute after:inset-0" href={cluster.hubRoute}>{cluster.title}</a>
      </h3>
    </div>

    <!-- Body: pain points + stats (grows to push footer to bottom) -->
    <div class="mt-5 flex flex-1 flex-col">
      <div class="space-y-2.5">
        {cluster.painPoints.slice(0, 3).map((pain) => (
          <div class="flex items-start gap-2.5">
            <span class={`mt-[7px] h-[5px] w-[5px] shrink-0 rounded-full ${isUrgent ? 'bg-red-500' : 'bg-bronze-400'}`}></span>
            <span class="text-sm leading-snug text-stone-600">{pain}</span>
          </div>
        ))}
      </div>

      <!-- Stats strip — always at bottom of body -->
      <div class="mt-auto flex items-baseline gap-5 border-t border-stone-100 pt-5">
        {cluster.stats.slice(0, 2).map((stat) => (
          <div class="flex flex-col">
            <span class="font-serif text-xl font-bold tracking-tight text-navy-950">{stat.value}</span>
            <span class="mt-0.5 text-[10px] font-semibold uppercase tracking-wider text-stone-400">{stat.label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Footer: always at card bottom, aligned with siblings -->
    <div class="mt-6 flex items-center justify-between">
      <span class={`inline-flex items-center gap-1.5 text-sm font-semibold transition group-hover:translate-x-0.5 ${isUrgent ? 'text-red-500 group-hover:text-red-400' : 'text-bronze-600 group-hover:text-bronze-400'}`}>
        Ver guias essenciais
        <svg class="h-4 w-4 transition group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </span>
      <div class="flex items-center gap-2">
        <span class="rounded-full border border-stone-200 bg-cream-50 px-3 py-1 text-xs font-medium text-stone-500">{articles.length} artigos</span>
        {checklist && <span class="rounded-full border border-emerald-500/20 bg-emerald-500/10 px-3 py-1 text-xs font-medium text-emerald-600">Lista</span>}
      </div>
    </div>

  </div>
</article>
