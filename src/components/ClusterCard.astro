---
import type { Cluster } from '../lib/taxonomy';
import { getArticlesByCluster } from '../lib/taxonomy';

interface Props {
  cluster: Cluster;
}

const { cluster } = Astro.props;
const articles = getArticlesByCluster(cluster.slug);
---

<article class="group relative overflow-hidden rounded-2xl border border-[rgba(201,168,108,0.12)] bg-navy-800/50 p-6 transition duration-300 hover:-translate-y-1 hover:border-bronze-500/30 hover:bg-navy-800 hover:shadow-xl hover:shadow-black/20">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-bronze-400/40 to-transparent opacity-0 transition group-hover:opacity-100" aria-hidden="true"></div>
  <p class="mb-3 text-[11px] font-semibold uppercase tracking-[0.2em] text-stone-500">Hub</p>
  <h3 class="font-serif text-2xl font-semibold tracking-tight text-cream-50">
    <a class="after:absolute after:inset-0" href={cluster.hubRoute}>{cluster.title}</a>
  </h3>
  <p class="mt-3 text-sm leading-7 text-stone-400">{cluster.summary}</p>
  <div class="mt-6 flex items-center justify-between gap-3 text-sm">
    <span class="font-semibold text-bronze-400 transition group-hover:text-gold-300">Ver guias essenciais</span>
    <span class="rounded-full border border-[rgba(201,168,108,0.12)] bg-navy-900/80 px-3 py-1 text-xs font-medium text-stone-400">{articles.length} artigos</span>
  </div>
</article>
