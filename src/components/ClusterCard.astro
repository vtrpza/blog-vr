---
import type { Cluster } from '../lib/taxonomy';
import { getArticlesByCluster } from '../lib/taxonomy';

interface Props {
  cluster: Cluster;
}

const { cluster } = Astro.props;
const articles = getArticlesByCluster(cluster.slug);
---

<article class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm transition hover:-translate-y-1 hover:shadow-md">
  <p class="mb-3 text-xs font-black uppercase tracking-[0.25em] text-blue-700">Hub</p>
  <h3 class="text-2xl font-black tracking-tight text-slate-950">
    <a href={cluster.hubRoute}>{cluster.title}</a>
  </h3>
  <p class="mt-3 text-sm leading-7 text-slate-600">{cluster.summary}</p>
  <div class="mt-5 flex items-center justify-between gap-3 text-sm font-bold">
    <a class="text-blue-700 hover:text-blue-900" href={cluster.hubRoute}>Ver guias essenciais</a>
    <span class="rounded-full bg-slate-100 px-3 py-1 text-slate-600">{articles.length} artigos</span>
  </div>
</article>
