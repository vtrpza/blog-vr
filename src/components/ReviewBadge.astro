---
interface Props {
  name: string;
  oab: string;
  date?: string;
}

const { name, oab, date } = Astro.props;
---

<div class="mt-6 rounded-2xl border border-[rgba(201,168,108,0.12)] bg-navy-950/60 px-5 py-4 text-sm text-stone-500">
  <span class="inline-flex items-center gap-2">
    <svg class="h-4 w-4 text-bronze-400" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
    Conteúdo revisado por <strong class="font-medium text-cream-50">{name}</strong>
    <span class="text-stone-500">— {oab}</span>
    {date && <span class="text-stone-500">· {date}</span>}
  </span>
</div>
