---
import type { LeadCta } from '../lib/taxonomy';

interface Props {
  cta: LeadCta;
  cluster?: string;
  intent?: string;
  articleSlug?: string;
  headline?: string;
  body?: string;
}

const { cta, cluster, intent, articleSlug, headline = 'Não deixe o banco definir seu próximo passo', body = 'Fale com um advogado especializado em direito bancário. A análise inicial é gratuita e sem compromisso.' } = Astro.props;
const isWhatsApp = cta.type === 'whatsapp';
const isExternal = cta.href.startsWith('http');
const icon = isWhatsApp
  ? `<svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`
  : `<svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" stroke-linecap="round" stroke-linejoin="round"/></svg>`;
---

<aside class="rounded-2xl border border-[rgba(201,168,108,0.15)] bg-navy-900/60 p-5 shadow-lg shadow-black/10">
  <p class="text-xs font-semibold uppercase tracking-[0.18em] text-bronze-400">Próximo passo</p>
  <h2 class="mt-2 font-serif text-xl font-medium text-cream-50">{headline}</h2>
  <p class="mt-2 text-sm leading-6 text-stone-400">{body}</p>
  <a
    href={cta.href}
    target={isExternal ? '_blank' : undefined}
    rel={isExternal ? 'noopener noreferrer' : undefined}
    class="mt-4 inline-flex w-full items-center justify-center gap-2 rounded-full bg-bronze-500 px-4 py-3 text-sm font-semibold text-navy-950 shadow-lg shadow-bronze-500/15 transition hover:bg-gold-300"
    data-track-cta
    data-cta-type={cta.type}
    data-cta-position="article_sidebar"
    data-cluster={cluster}
    data-page-type="article"
    data-intent={intent}
    data-article-slug={articleSlug}
  >
    <Fragment set:html={icon} />
    {cta.label}
  </a>
  <p class="mt-3 text-xs leading-5 text-stone-500">Resposta em até 24h úteis. Dados tratados conforme LGPD.</p>
</aside>
