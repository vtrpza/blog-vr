---
import LeadCtaButton from './LeadCta.astro';
import type { Cluster, ArticleRoute, ChecklistRoute, Intent, LeadCta } from '../lib/taxonomy';

interface Props {
  cluster: Cluster;
  articles: ArticleRoute[];
  checklist?: ChecklistRoute | null;
}

const { cluster, articles, checklist } = Astro.props;
const hubCtas: LeadCta[] = [cluster.primaryCta, cluster.secondaryCta].filter((cta): cta is LeadCta => !!cta);

const intentMeta: Record<
  Intent,
  { label: string; classes: string }
> = {
  urgent: { label: 'Urgente', classes: 'bg-rose-500/15 text-rose-300 border-rose-500/25' },
  informational: { label: 'Guia', classes: 'bg-sky-500/15 text-sky-300 border-sky-500/25' },
  'commercial-investigation': { label: 'Avaliação', classes: 'bg-bronze-500/15 text-bronze-300 border-bronze-500/25' },
  comparison: { label: 'Comparação', classes: 'bg-emerald-500/15 text-emerald-300 border-emerald-500/25' },
  checklist: { label: 'Checklist', classes: 'bg-violet-500/15 text-violet-300 border-violet-500/25' },
};

function articleSnippet(article: ArticleRoute): string {
  switch (article.intent) {
    case 'urgent':
      return `Passo a passo imediato para quem busca "${article.primaryKeyword}" sem perder tempo.`;
    case 'comparison':
      return `Compare dados oficiais com seu contrato sobre "${article.primaryKeyword}".`;
    case 'commercial-investigation':
      return `Descubra se vale a pena mover seu caso sobre "${article.primaryKeyword}".`;
    case 'checklist':
      return `Lista de documentos e verificações para "${article.primaryKeyword}".`;
    default:
      return `Guia completo sobre "${article.primaryKeyword}": direitos, erros e próximos passos.`;
  }
}

const checklistData = checklist ?? null;
---

<!-- ═══ HERO HUB ═══ -->
<section class="relative overflow-hidden border-b border-[rgba(201,168,108,0.10)] bg-navy-900/40">
  <!-- Glows -->
  <div class="absolute -right-40 -top-40 h-[28rem] w-[28rem] rounded-full bg-bronze-500/5 blur-3xl" aria-hidden="true"></div>
  <div class="absolute -left-20 top-1/2 h-80 w-80 -translate-y-1/2 rounded-full bg-gold-300/5 blur-3xl" aria-hidden="true"></div>

  <div class="relative mx-auto grid max-w-6xl gap-10 px-5 py-20 lg:grid-cols-[1.2fr_0.8fr] lg:items-center lg:py-28">
    <div>
      <!-- Breadcrumb -->
      <a class="inline-flex items-center gap-1 text-sm font-medium text-stone-500 transition hover:text-cream-50" href="/">
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M15 19l-7-7 7-7" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
        Início
      </a>

      <p class="mt-8 inline-flex items-center gap-2 rounded-full border border-bronze-500/30 bg-bronze-500/15 px-4 py-2 text-xs font-bold uppercase tracking-[0.18em] text-bronze-400 backdrop-blur">
        <span class="h-2 w-2 animate-pulse rounded-full bg-bronze-400 shadow-[0_0_8px_rgba(201,168,108,0.6)]"></span>
        {cluster.tagline}
      </p>

      <h1 class="mt-6 max-w-4xl font-serif text-4xl font-bold tracking-tight text-cream-50 md:text-6xl" set:html={cluster.headline} />

      <p class="mt-6 max-w-3xl text-lg leading-8 text-stone-300">
        {cluster.subhead}
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-4">
        {hubCtas.map((cta) => (
          <LeadCtaButton cta={cta} cluster={cluster.slug} pageType="hub" />
        ))}
      </div>

      <div class="mt-6 flex flex-wrap gap-2">
        {cluster.valueProp.map((item) => (
          <span class="inline-flex items-center gap-1.5 rounded-full border border-[rgba(201,168,108,0.12)] bg-navy-950/50 px-3 py-1.5 text-xs font-medium text-stone-400">
            <svg class="h-3.5 w-3.5 text-bronze-400" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            {item}
          </span>
        ))}
      </div>
    </div>

    <!-- Stats card -->
    <div class="relative overflow-hidden rounded-3xl border border-bronze-500/20 bg-navy-900/70 p-8 shadow-2xl shadow-black/40 backdrop-blur glow-bronze">
      <div class="absolute -right-10 -top-10 h-40 w-40 rounded-full bg-bronze-500/10 blur-2xl" aria-hidden="true"></div>
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-stone-500">Prova da VR nesta frente</p>
      <div class="mt-6 grid gap-3">
        {cluster.stats.map((stat) => (
          <div class="flex items-center justify-between rounded-xl border border-[rgba(201,168,108,0.10)] bg-navy-950/60 p-4">
            <p class="font-serif text-2xl font-semibold text-cream-50">{stat.value}</p>
            <p class="max-w-[55%] text-right text-xs leading-5 text-stone-400">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<!-- ═══ DOR / CONTEXT ═══ -->
<section class="mx-auto max-w-6xl px-5 py-20">
  <div class="max-w-3xl">
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-bronze-400">Sinais de alerta</p>
    <h2 class="mt-4 font-serif text-3xl font-semibold tracking-tight text-cream-50 md:text-4xl">Se você se reconhece em alguma dessas situações, este hub é para você.</h2>
  </div>
  <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
    {cluster.painPoints.map((pain) => (
      <div class="rounded-2xl border border-[rgba(201,168,108,0.10)] bg-navy-900/40 p-6 transition hover:border-bronze-500/20 hover:bg-navy-900/60">
        <span class="flex h-10 w-10 items-center justify-center rounded-full bg-bronze-500/15 text-lg text-bronze-400">🚨</span>
        <p class="mt-4 text-sm leading-7 text-stone-300">{pain}</p>
      </div>
    ))}
  </div>
</section>

<hr class="section-divider" />

<!-- ═══ ARTIGOS DO HUB ═══ -->
<section class="mx-auto max-w-6xl px-5 py-20" id="guias">
  <div class="flex flex-col justify-between gap-6 lg:flex-row lg:items-end">
    <div class="max-w-2xl">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-bronze-400">Conteúdo do hub</p>
      <h2 class="mt-4 font-serif text-3xl font-semibold tracking-tight text-cream-50 md:text-4xl">Guias para ir do caos à decisão.</h2>
      <p class="mt-4 text-lg leading-8 text-stone-400">Cada artigo foi escrito para uma etapa diferente: apagar fogo, comparar, decidir ou preparar documentos.</p>
    </div>
    {checklistData && (
      <a class="inline-flex items-center gap-2 rounded-full border border-bronze-500/30 bg-bronze-500/10 px-5 py-2.5 text-sm font-semibold text-bronze-400 transition hover:bg-bronze-500/20" href={checklistData.route}>
        Ver checklist de documentos
        <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    )}
  </div>

  <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
    {articles.map((article) => {
      const intent = intentMeta[article.intent];
      return (
        <article class="group relative flex flex-col overflow-hidden rounded-2xl border border-[rgba(201,168,108,0.10)] bg-navy-900/40 p-6 transition duration-300 hover:-translate-y-1 hover:border-bronze-500/25 hover:bg-navy-900/60 hover:shadow-xl hover:shadow-black/20">
          <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-bronze-400/40 to-transparent opacity-0 transition group-hover:opacity-100" aria-hidden="true"></div>
          <div class="flex items-center justify-between gap-3">
            <span class={`inline-flex rounded-full border px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wider ${intent.classes}`}>{intent.label}</span>
            <span class="text-[10px] font-semibold uppercase tracking-[0.15em] text-stone-500">{cluster.shortTitle}</span>
          </div>
          <h3 class="mt-5 font-serif text-xl font-semibold tracking-tight text-cream-50">
            <a class="transition group-hover:text-gold-300" href={article.route}>{article.title}</a>
          </h3>
          <p class="mt-3 flex-1 text-sm leading-7 text-stone-400">{articleSnippet(article)}</p>
          <div class="mt-6 flex items-center justify-between gap-3 border-t border-[rgba(201,168,108,0.08)] pt-5">
            <span class="text-xs font-semibold text-bronze-400 transition group-hover:text-gold-300">Ler guia</span>
            <span class="rounded-full border border-[rgba(201,168,108,0.12)] bg-navy-950/80 px-3 py-1 text-[10px] font-medium uppercase tracking-wide text-stone-500">{article.primaryKeyword}</span>
          </div>
        </article>
      );
    })}
  </div>
</section>

<!-- ═══ CHECKLIST EMBUTIDO ═══ -->
{checklistData && (
  <section class="mx-auto max-w-6xl px-5 pb-24">
    <div class="relative overflow-hidden rounded-[2rem] border border-[rgba(201,168,108,0.12)] bg-navy-900/60 p-8 md:p-12">
      <div class="absolute -right-20 -top-20 h-72 w-72 rounded-full bg-bronze-500/5 blur-3xl" aria-hidden="true"></div>
      <div class="relative grid gap-10 lg:grid-cols-[1fr_0.6fr] lg:items-center">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-bronze-400">Checklist gratuito</p>
          <h2 class="mt-3 font-serif text-2xl font-semibold tracking-tight text-cream-50 md:text-3xl">Junte os documentos certos antes de falar com o banco.</h2>
          <p class="mt-4 text-stone-400">{checklistData.title} — marque o que você já tem e use a lista para não deixar ninguém te enrolar.</p>
          <ul class="mt-6 space-y-3">
            {checklistData.items.slice(0, 4).map((item) => (
              <li class="flex items-start gap-3 text-sm text-stone-300">
                <span class="mt-0.5 flex h-5 w-5 shrink-0 items-center justify-center rounded-full border border-bronze-500/30 text-[10px] text-bronze-400">✓</span>
                {item}
              </li>
            ))}
          </ul>
          <div class="mt-8 flex flex-wrap items-center gap-4">
            <a class="group inline-flex items-center justify-center gap-2 rounded-full bg-bronze-500 px-6 py-3 text-sm font-semibold text-navy-950 shadow-lg shadow-bronze-500/15 transition hover:bg-gold-300" href={checklistData.route}>
              Abrir checklist completo
              <svg class="h-4 w-4 transition group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
            <LeadCtaButton cta={checklistData.cta} cluster={cluster.slug} pageType="checklist" />
          </div>
        </div>
        <div class="rounded-2xl border border-[rgba(201,168,108,0.10)] bg-navy-950/50 p-6">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-500">Por que a documentação importa?</p>
          <p class="mt-3 text-sm leading-7 text-stone-400">Banco não para de bater na porta. Quem chega com documento na mão chega com poder de negociação. O checklist elimina desculpa e aumenta a chance de boa proposta.</p>
        </div>
      </div>
    </div>
  </section>
)}

<!-- ═══ CTA FINAL HUB ═══ -->
<section class="mx-auto max-w-6xl px-5 pb-24">
  <div class="relative overflow-hidden rounded-[2rem] border border-[rgba(201,168,108,0.15)] bg-gradient-to-br from-navy-800 to-navy-900 p-8 md:p-14 stat-pulse">
    <div class="absolute -right-20 -top-20 h-80 w-80 rounded-full bg-bronze-500/10 blur-3xl" aria-hidden="true"></div>
    <div class="absolute -left-20 -bottom-20 h-60 w-60 rounded-full bg-gold-300/5 blur-3xl" aria-hidden="true"></div>
    <div class="relative max-w-3xl">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-bronze-400">Próximo passo</p>
      <h2 class="mt-3 font-serif text-3xl font-semibold tracking-tight text-cream-50 md:text-4xl">Não leia para sempre. <span class="text-gradient">Decida o que fazer.</span></h2>
      <p class="mt-5 text-lg leading-8 text-stone-300">A VR analisa seu caso, aponta a brecha e te diz honestamente se vale a pena seguir. Sem custo inicial. Sem palpite.</p>
      <div class="mt-8 flex flex-wrap items-center gap-4">
        <LeadCtaButton cta={cluster.primaryCta} cluster={cluster.slug} pageType="hub" />
        <a class="inline-flex items-center gap-2 rounded-full px-6 py-3 text-sm font-semibold text-bronze-400 transition hover:text-gold-300" href="/">
          Voltar para a home
          <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 12h18M3 12l6-6m-6 6l6 6" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
