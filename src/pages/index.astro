---
import ClusterCard from '../components/ClusterCard.astro';
import LeadCtaButton from '../components/LeadCta.astro';
import YouTubeBackground from '../components/YouTubeBackground.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { CLUSTERS, type LeadCta as LeadCtaConfig } from '../lib/taxonomy';
import { organizationSchema, websiteSchema } from '../lib/seo';

const heroCta: LeadCtaConfig = {
  type: 'diagnostic',
  label: 'Quero reduzir minhas dívidas agora',
  href: '/diagnostico-inicial/',
  position: 'home_hero',
};

const ticker = [
  { label: 'Taxa Selic', value: '14,25%', unit: 'a.a.' },
  { label: 'IPCA', value: '0,58%', unit: 'mês' },
  { label: 'Juros Veículos', value: '26,31%', unit: 'a.a.' },
  { label: 'CDI', value: '14,15%', unit: 'a.a.' },
  { label: 'Consignado', value: '6,81%', unit: 'a.a.' },
  { label: 'Pessoal', value: '33,42%', unit: 'a.a.' },
];

const valdecirStats = [
  { value: 'R$ 500M+', label: 'Negociados', icon: '💰' },
  { value: '11.000+', label: 'Processos ativos', icon: '⚔️' },
  { value: '14 anos', label: 'Inimigo dos bancos', icon: '🏛️' },
  { value: '47K+', label: 'Seguidores', icon: '📈' },
];

const pillars = [
  {
    tag: 'Método',
    title: 'Cada caso é uma emboscada.',
    text: 'Nada de solução de prateleira. Dissecamos contrato por contrato, cláusula por cláusula, até achar a brecha onde o banco errou. É nessa rachadura que entra a faca.',
  },
  {
    tag: 'Foco exclusivo',
    title: 'Só Direito Bancário. Nada mais.',
    text: 'Não somos escritório de "faz de tudo". Cada hora da equipe é investida em uma única frente: destruir contratos abusivos e devolver o dinheiro que o banco tirou de você.',
  },
  {
    tag: 'Só caso ganhável',
    title: 'Só aceitamos caso que tem brecha.',
    text: 'Se não há rachadura no contrato, a gente te diz na primeira análise — e não cobra palpite. Quando a VR assume, é porque já enxergou onde o banco vacilou.',
  },
];
---

<BaseLayout
  title="VR Advogados — O Inimigo nº1 dos Bancos"
  description="R$ 500 milhões negociados. 11 mil processos ativos. Dr. Valdecir Rabelo, referência nacional em Direito Bancário. Reduza suas dívidas agora."
  canonicalPath="/"
  pageType="home"
  jsonLd={[organizationSchema(), websiteSchema()]}
>
  <!-- ═══ Running Ticker ═══ -->
  <div class="overflow-hidden border-b border-[rgba(201,168,108,0.10)] bg-navy-900/60 py-2.5">
    <div class="flex overflow-hidden">
      <div class="ticker-track shrink-0 select-none text-xs font-medium uppercase tracking-[0.15em] text-stone-400">
        {[
          ...ticker,
          ...ticker,
        ].map((item) => (
          <span class="inline-flex items-center gap-2 whitespace-nowrap">
            <span class="text-[10px] text-bronze-400">●</span>
            {item.label}
            <strong class="font-semibold text-cream-50">{item.value}</strong>
            <span class="text-stone-500">{item.unit}</span>
          </span>
        ))}
      </div>
    </div>
  </div>

  <!-- ═══ Hero ═══ -->
  <section class="relative overflow-hidden border-b border-[rgba(201,168,108,0.10)]">
    <!-- Background video local — zero YouTube chrome, zero postMessage, zero cookies -->
    <!-- MP4 baixado do YouTube via yt-dlp. Ver YouTubeBackground.astro para detalhes. -->
    <YouTubeBackground />

    <!-- Overlay layers -->
    <div class="absolute inset-0 bg-gradient-to-b from-navy-950/70 via-navy-950/60 to-navy-950/95 z-[1]" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-bronze-500/15 via-transparent to-transparent z-[1]" aria-hidden="true"></div>
    <div class="absolute -top-40 left-1/2 h-[36rem] w-[36rem] -translate-x-1/2 rounded-full bg-bronze-500/5 blur-3xl z-[1]" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto grid max-w-6xl gap-12 px-5 py-24 lg:grid-cols-[1.1fr_0.9fr] lg:items-center lg:py-32">
      <div>
        <!-- Badge -->
        <p class="mb-6 inline-flex items-center gap-2 rounded-full border border-bronze-500/30 bg-bronze-500/15 px-4 py-2 text-xs font-bold uppercase tracking-[0.18em] text-bronze-400 backdrop-blur">
          <span class="h-2 w-2 animate-pulse rounded-full bg-bronze-400 shadow-[0_0_8px_rgba(201,168,108,0.6)]"></span>
          O inimigo nº1 dos bancos desde 2012
        </p>

        <!-- Headline -->
        <h1 class="max-w-3xl font-serif text-5xl font-bold tracking-tight text-cream-50 md:text-7xl lg:text-8xl">
          Seu banco <span class="text-gradient">treme</span> quando ele entra na sala.
        </h1>

        <!-- Subhead -->
        <p class="mt-7 max-w-2xl text-lg leading-8 text-stone-300">
          <strong class="text-cream-50">Dr. Valdecir Rabelo.</strong> O advogado que já arrancou <strong class="text-bronze-400">R$ 500 milhões</strong> das garras dos bancos. 
          11 mil processos ativos. 14 anos de guerra contra juros abusivos, busca e apreensão e contratos ilegais. 
          Enquanto outros prometem, ele <strong class="text-cream-50">executa</strong>.
        </p>

        <!-- CTAs -->
        <div class="mt-9 flex flex-wrap items-center gap-4">
          <LeadCtaButton cta={heroCta} pageType="home" />
          <a class="inline-flex items-center justify-center gap-2 rounded-full border border-[rgba(201,168,108,0.25)] bg-white/5 px-6 py-3 text-sm font-semibold text-cream-50 backdrop-blur transition hover:bg-white/10" href="#problemas">
            Escolher meu problema
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Valdecir Stats Card -->
      <div class="relative overflow-hidden rounded-3xl border border-bronze-500/20 bg-navy-900/70 shadow-2xl shadow-black/40 backdrop-blur glow-bronze">
        <div class="absolute -right-10 -top-10 h-40 w-40 rounded-full bg-bronze-500/10 blur-2xl" aria-hidden="true"></div>
        <div class="relative p-8">
          <div class="flex items-center justify-between">
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-stone-500">Quem vai te defender</p>
            <span class="rounded-full border border-emerald-500/30 bg-emerald-500/15 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-emerald-300">Nº1 do Brasil</span>
          </div>
          <p class="mt-4 font-serif text-3xl font-bold tracking-tight text-cream-50">Dr. Valdecir Rabelo</p>
          <p class="mt-2 text-sm font-semibold uppercase tracking-[0.15em] text-bronze-400">OAB/ES 26.575 · Fundador & Presidente</p>
          <div class="mt-6 grid grid-cols-2 gap-3">
            {valdecirStats.map((stat) => (
              <div class="rounded-xl border border-[rgba(201,168,108,0.12)] bg-navy-950/60 p-4">
                <p class="text-2xl font-bold text-cream-50">{stat.value}</p>
                <p class="mt-1 text-xs text-stone-400">{stat.icon} {stat.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ Social Proof Strip ═══ -->
  <section class="bg-navy-900/80 border-b border-[rgba(201,168,108,0.10)] py-10">
    <div class="mx-auto max-w-6xl px-5 text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-stone-500">Referência nacional em Direito Bancário</p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-8 text-stone-400">
        <span class="flex items-center gap-2 text-sm"><span class="text-bronze-400 font-bold">+9.000</span> clientes atendidos</span>
        <span class="hidden h-4 w-px bg-[rgba(201,168,108,0.15)] sm:block" aria-hidden="true"></span>
        <span class="flex items-center gap-2 text-sm"><span class="text-bronze-400 font-bold">Presença</span> em todo o Brasil</span>
        <span class="hidden h-4 w-px bg-[rgba(201,168,108,0.15)] sm:block" aria-hidden="true"></span>
        <span class="flex items-center gap-2 text-sm"><span class="text-bronze-400 font-bold">1.075+</span> avaliações 5 estrelas</span>
        <span class="hidden h-4 w-px bg-[rgba(201,168,108,0.15)] sm:block" aria-hidden="true"></span>
        <span class="flex items-center gap-2 text-sm"><span class="text-bronze-400 font-bold">4</span> escritórios (RJ, SP, ES)</span>
      </div>
    </div>
  </section>

  <!-- ═══ Recado do Fundador ═══ -->
  <section class="mx-auto max-w-6xl px-5 py-24">
    <div class="grid gap-10 lg:grid-cols-2 lg:items-center">
      <!-- Foto — fade estilizado com bordas douradas -->
      <div class="relative flex justify-center">
        <!-- Moldura dourada externa -->
        <div class="relative w-full max-w-md">
          <!-- Glow por trás -->
          <div class="absolute -inset-1 rounded-2xl bg-gradient-to-br from-bronze-400 via-gold-300/60 to-bronze-600 blur-lg opacity-40" aria-hidden="true"></div>
          <!-- Borda dourada -->
          <div class="absolute -inset-[2px] rounded-2xl bg-gradient-to-br from-bronze-400 via-gold-300 to-bronze-500" aria-hidden="true"></div>
          <!-- Container da foto com fade edges -->
          <div class="relative overflow-hidden rounded-2xl">
            <img
              src="/assets/images/valdecir-portrait.png"
              alt="Dr. Valdecir Rabelo Filho — Fundador da VR Advogados"
              class="w-full object-cover grayscale contrast-125"
              loading="lazy"
            />
            <!-- Fade: gradiente lateral apagando para o fundo -->
            <div class="absolute inset-0 bg-gradient-to-r from-navy-950/95 via-navy-950/20 to-navy-950/95 pointer-events-none" aria-hidden="true"></div>
            <!-- Fade inferior: dissolve para baixo -->
            <div class="absolute bottom-0 left-0 right-0 h-1/2 bg-gradient-to-t from-navy-950/90 to-transparent pointer-events-none" aria-hidden="true"></div>
            <!-- Fade superior sutil -->
            <div class="absolute top-0 left-0 right-0 h-1/4 bg-gradient-to-b from-navy-950/70 to-transparent pointer-events-none" aria-hidden="true"></div>
            <!-- Texto sobre a foto -->
            <div class="absolute bottom-0 left-0 right-0 p-6 z-10">
              <p class="font-serif text-xl font-semibold text-cream-50 drop-shadow-lg">Dr. Valdecir Rabelo Filho</p>
              <p class="text-sm text-bronze-400 drop-shadow">Fundador & Presidente</p>
            </div>
          </div>
          <!-- Cantos dourados decorativos (4 cantos) -->
          <div class="absolute -top-1 -left-1 h-8 w-8 border-l-2 border-t-2 border-gold-300 rounded-tl-lg" aria-hidden="true"></div>
          <div class="absolute -top-1 -right-1 h-8 w-8 border-r-2 border-t-2 border-gold-300 rounded-tr-lg" aria-hidden="true"></div>
          <div class="absolute -bottom-1 -left-1 h-8 w-8 border-l-2 border-b-2 border-gold-300 rounded-bl-lg" aria-hidden="true"></div>
          <div class="absolute -bottom-1 -right-1 h-8 w-8 border-r-2 border-b-2 border-gold-300 rounded-br-lg" aria-hidden="true"></div>
        </div>
      </div>

      <!-- Texto + assinatura -->
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-bronze-400">Um recado do fundador</p>
        <blockquote class="mt-4 font-serif text-2xl font-medium leading-relaxed tracking-tight text-cream-50 md:text-3xl">
          "Desde os meus primeiros passos no campo jurídico, tracei uma trajetória impulsionada pela paixão de enfrentar desafios complexos na esfera bancária. Em 2012, conquistei minha primeira vitória contra instituições financeiras, marcando o início de uma missão que impacta vidas."
        </blockquote>
        <div class="mt-8">
          <img
            src="/assets/images/ass-valdecir.png"
            alt="Assinatura Valdecir Rabelo Filho"
            class="h-14 w-auto brightness-0 invert opacity-80"
            loading="lazy"
          />
          <p class="mt-2 text-sm text-stone-500">Valdecir Rabelo Filho — OAB/ES 26.575</p>
        </div>
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ═══ Áreas de atuação ═══ -->
  <section id="problemas" class="mx-auto max-w-6xl px-5 py-24">
    <div class="flex flex-col justify-between gap-6 lg:flex-row lg:items-end">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-bronze-400">Escolha por dor</p>
        <h2 class="mt-4 font-serif text-4xl font-semibold tracking-tight text-cream-50 md:text-5xl">Áreas de atuação</h2>
        <p class="mt-4 text-lg leading-8 text-stone-400">Cada hub reúne guias, checklists e diagnóstico contextual para uma intenção comercial forte.</p>
      </div>
      <a class="hidden text-sm font-semibold text-bronze-400 transition hover:text-gold-300 lg:block" href="/diagnostico-inicial/">Não sabe por onde começar? →</a>
    </div>
    <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {CLUSTERS.map((cluster) => <ClusterCard cluster={cluster} />)}
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ═══ Como trabalhamos ═══ -->
  <section class="relative overflow-hidden border-y border-[rgba(201,168,108,0.10)] bg-navy-900/30 py-24">
    <div class="absolute -right-32 top-1/4 h-96 w-96 rounded-full bg-bronze-500/5 blur-3xl" aria-hidden="true"></div>
    <div class="absolute -left-20 bottom-0 h-72 w-72 rounded-full bg-gold-300/5 blur-3xl" aria-hidden="true"></div>

    <div class="relative mx-auto max-w-6xl px-5">
      <div class="max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-bronze-400">Por que nos escolher</p>
        <h2 class="mt-4 font-serif text-3xl font-semibold tracking-tight text-cream-50 md:text-4xl">Outros prometem. <span class="text-gradient">A VR executa.</span></h2>
        <p class="mt-5 text-lg leading-8 text-stone-400">Os números você já viu acima. Aqui é onde a gente explica <strong class="text-cream-50">como</strong> — e por que só aceitamos caso que tem brecha.</p>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {pillars.map((pillar) => (
          <div class="rounded-2xl border border-[rgba(201,168,108,0.10)] bg-navy-950/60 p-7 transition card-lift">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-500">{pillar.tag}</p>
            <h3 class="mt-4 font-serif text-xl font-medium tracking-tight text-cream-50">{pillar.title}</h3>
            <p class="mt-3 text-sm leading-7 text-stone-400">{pillar.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <hr class="section-divider" />

  <!-- ═══ CTA Final ═══ -->
  <section class="mx-auto max-w-6xl px-5 py-24">
    <div class="relative overflow-hidden rounded-[2rem] border border-[rgba(201,168,108,0.15)] bg-gradient-to-br from-navy-800 to-navy-900 p-8 md:p-14 stat-pulse">
      <div class="absolute -right-20 -top-20 h-80 w-80 rounded-full bg-bronze-500/10 blur-3xl" aria-hidden="true"></div>
      <div class="absolute -left-20 -bottom-20 h-60 w-60 rounded-full bg-gold-300/5 blur-3xl" aria-hidden="true"></div>
      <div class="relative max-w-3xl">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-bronze-400">Próximo passo</p>
        <h2 class="mt-3 font-serif text-3xl font-semibold tracking-tight text-cream-50 md:text-4xl">Seu caso tem <span class="text-gradient">brecha?</span> Em 24h a gente te diz.</h2>
        <p class="mt-5 text-lg leading-8 text-stone-300">Mande o contrato, a cobrança ou o mandado. A VR analisa, acha a brecha — ou te diz honestamente que não tem. Sem palpite, sem custo por análise inicial.</p>
        <div class="mt-8 flex flex-wrap items-center gap-4">
          <LeadCtaButton cta={heroCta} pageType="home" />
          <a class="inline-flex items-center gap-2 rounded-full px-6 py-3 text-sm font-semibold text-bronze-400 transition hover:text-gold-300" href="/sobre-o-blog/">
            Conhecer o blog
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>