---
import ClusterCard from '../components/ClusterCard.astro';
import LeadCtaButton from '../components/LeadCta.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { CLUSTERS, type LeadCta as LeadCtaConfig } from '../lib/taxonomy';
import { organizationSchema, websiteSchema } from '../lib/seo';

const heroCta: LeadCtaConfig = {
  type: 'diagnostic',
  label: 'Começar diagnóstico inicial',
  href: '/diagnostico-inicial/',
  position: 'home_hero',
};

const pillars = [
  {
    tag: 'Conteúdo',
    title: 'Por intenção, não por acaso',
    text: 'Cada rota responde uma dúvida real. Slugs estáveis, schema e links internos desde o primeiro build.',
  },
  {
    tag: 'Conversão',
    title: 'CTA que respeita o problema',
    text: 'WhatsApp, formulário, checklist e diagnóstico mudam conforme a urgência e o cluster do visitante.',
  },
  {
    tag: 'Dados',
    title: 'Tracking antes do tráfego',
    text: 'dataLayer pronto para article_view, hub_view, cta_click, whatsapp_click e generate_lead.',
  },
];
---

<BaseLayout
  title="VR Advogados — Direito Bancário"
  description="Orientação jurídica sob medida para problemas bancários: busca e apreensão, juros abusivos, dívidas PJ, superendividamento, cobranças indevidas e fraudes."
  canonicalPath="/"
  pageType="home"
  jsonLd={[organizationSchema(), websiteSchema()]}
>
  <section class="relative overflow-hidden border-b border-[rgba(201,168,108,0.10)]">
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-navy-800/60 via-navy-950 to-navy-950" aria-hidden="true"></div>
    <div class="absolute -top-40 left-1/2 h-[36rem] w-[36rem] -translate-x-1/2 rounded-full bg-bronze-500/5 blur-3xl" aria-hidden="true"></div>

    <div class="relative mx-auto grid max-w-6xl gap-12 px-5 py-24 lg:grid-cols-[1.1fr_0.9fr] lg:items-center lg:py-32">
      <div>
        <p class="mb-6 inline-flex items-center gap-2 rounded-full border border-bronze-500/20 bg-bronze-500/10 px-4 py-2 text-xs font-semibold uppercase tracking-[0.18em] text-bronze-400">
          <span class="h-1.5 w-1.5 rounded-full bg-bronze-400"></span>
          Escritório especializado em direito bancário
        </p>
        <h1 class="max-w-3xl font-serif text-5xl font-semibold tracking-tight text-cream-50 md:text-7xl">
          Defesa técnica para quem está na contramão do <span class="text-gradient">banco</span>.
        </h1>
        <p class="mt-7 max-w-2xl text-lg leading-8 text-stone-400">
          Conteúdo informativo, checklists e diagnóstico inicial para transformar dúvida em próximo passo seguro — sem promessa de resultado e sem firula institucional.
        </p>
        <div class="mt-9 flex flex-wrap items-center gap-4">
          <LeadCtaButton cta={heroCta} pageType="home" />
          <a class="inline-flex items-center justify-center gap-2 rounded-full border border-[rgba(201,168,108,0.25)] px-6 py-3 text-sm font-semibold text-cream-50 transition hover:bg-white/5" href="#problemas">
            Escolher meu problema
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
      </div>

      <div class="relative rounded-3xl border border-[rgba(201,168,108,0.15)] bg-navy-900/60 p-8 shadow-2xl shadow-black/30 backdrop-blur glow-bronze">
        <div class="flex items-center justify-between">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-500">Foco do escritório</p>
          <span class="rounded-full border border-emerald-500/25 bg-emerald-500/10 px-2.5 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-emerald-300">Ativo</span>
        </div>
        <p class="mt-5 font-serif text-3xl font-medium tracking-tight text-cream-50">qualified_leads / eligible_sessions</p>
        <p class="mt-4 leading-7 text-stone-400">Pageview sem lead é só vaidade. O site nasce medindo CTA, diagnóstico, WhatsApp e cluster — para que cada decisão de marketing seja informada.</p>
        <div class="mt-7 grid grid-cols-2 gap-3">
          <div class="rounded-xl border border-[rgba(201,168,108,0.10)] bg-navy-950/60 p-4">
            <p class="text-2xl font-semibold text-cream-50">5</p>
            <p class="mt-1 text-xs text-stone-500">hubs principais</p>
          </div>
          <div class="rounded-xl border border-[rgba(201,168,108,0.10)] bg-navy-950/60 p-4">
            <p class="text-2xl font-semibold text-cream-50">27</p>
            <p class="mt-1 text-xs text-stone-500">guias publicados</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="problemas" class="mx-auto max-w-6xl px-5 py-24">
    <div class="flex flex-col justify-between gap-6 lg:flex-row lg:items-end">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-bronze-400">Escolha por dor</p>
        <h2 class="mt-4 font-serif text-4xl font-semibold tracking-tight text-cream-50 md:text-5xl">Áreas de atuação</h2>
        <p class="mt-4 text-lg leading-8 text-stone-400">Cada hub reúne guias, checklists e diagnóstico contextual para uma intenção comercial forte.</p>
      </div>
      <a class="hidden text-sm font-semibold text-bronze-400 transition hover:text-gold-300 lg:block" href="/diagnostico-inicial/">Não sabe por onde começar? →</a>
    </div>
    <div class="mt-12 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
      {CLUSTERS.map((cluster) => <ClusterCard cluster={cluster} />)}
    </div>
  </section>

  <section class="border-y border-[rgba(201,168,108,0.10)] bg-navy-900/30 py-24">
    <div class="mx-auto max-w-6xl px-5">
      <div class="max-w-2xl">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-bronze-400">Como trabalhamos</p>
        <h2 class="mt-4 font-serif text-3xl font-semibold tracking-tight text-cream-50 md:text-4xl">Site pensado como ferramenta de decisão.</h2>
      </div>
      <div class="mt-12 grid gap-6 md:grid-cols-3">
        {pillars.map((pillar) => (
          <div class="rounded-2xl border border-[rgba(201,168,108,0.10)] bg-navy-950/40 p-7 transition hover:border-bronze-500/20 hover:bg-navy-950/60">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-stone-500">{pillar.tag}</p>
            <h3 class="mt-4 font-serif text-xl font-medium tracking-tight text-cream-50">{pillar.title}</h3>
            <p class="mt-3 text-sm leading-7 text-stone-400">{pillar.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 py-24">
    <div class="relative overflow-hidden rounded-[2rem] border border-[rgba(201,168,108,0.15)] bg-gradient-to-br from-navy-800 to-navy-900 p-8 md:p-14">
      <div class="absolute -right-20 -top-20 h-80 w-80 rounded-full bg-bronze-500/10 blur-3xl" aria-hidden="true"></div>
      <div class="relative max-w-3xl">
        <h2 class="font-serif text-3xl font-semibold tracking-tight text-cream-50 md:text-4xl">Conteúdo informativo com padrão de escritório.</h2>
        <p class="mt-5 text-lg leading-8 text-stone-300">Se você tem contrato, cobrança ou negativação para avaliar, organize documentos e peça uma análise inicial. Resposta sem promessa, direcionamento sem automação.</p>
        <div class="mt-8">
          <LeadCtaButton cta={heroCta} pageType="home" />
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
