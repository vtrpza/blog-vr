---
import ClusterCard from '../components/ClusterCard.astro';
import LeadCtaButton from '../components/LeadCta.astro';
import YouTubeBackground from '../components/YouTubeBackground.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { CLUSTERS, type LeadCta as LeadCtaConfig } from '../lib/taxonomy';
import { organizationSchema, websiteSchema } from '../lib/seo';

const heroCta: LeadCtaConfig = {
  type: 'diagnostic',
  label: 'Quero reduzir minhas dívidas agora',
  href: '/diagnostico-inicial/',
  position: 'home_hero',
};

const ticker = [
  { label: 'Taxa Selic', value: '14,25%', unit: 'a.a.' },
  { label: 'IPCA', value: '0,58%', unit: 'mês' },
  { label: 'Juros Veículos', value: '26,31%', unit: 'a.a.' },
  { label: 'CDI', value: '14,15%', unit: 'a.a.' },
  { label: 'Consignado', value: '6,81%', unit: 'a.a.' },
  { label: 'Pessoal', value: '33,42%', unit: 'a.a.' },
];

const valdecirStats = [
  { value: 'R$ 500M+', label: 'Negociados', icon: '💰' },
  { value: '11.000+', label: 'Processos ativos', icon: '⚔️' },
  { value: '14 anos', label: 'Inimigo dos bancos', icon: '🏛️' },
  { value: '47K+', label: 'Seguidores', icon: '📈' },
];

const pillars = [
  {
    tag: 'Método',
    title: 'Cada caso é uma emboscada.',
    text: 'Nada de solução de prateleira. Dissecamos contrato por contrato, cláusula por cláusula, até achar a brecha onde o banco errou. É nessa rachadura que entra a faca.',
  },
  {
    tag: 'Foco exclusivo',
    title: 'Só Direito Bancário. Nada mais.',
    text: 'Não somos escritório de "faz de tudo". Cada hora da equipe é investida em uma única frente: destruir contratos abusivos e devolver o dinheiro que o banco tirou de você.',
  },
  {
    tag: 'Só caso ganhável',
    title: 'Só aceitamos caso que tem brecha.',
    text: 'Se não há rachadura no contrato, a gente te diz na primeira análise — e não cobra palpite. Quando a VR assume, é porque já enxergou onde o banco vacilou.',
  },
];
---

<BaseLayout
  title="VR Advogados — O Inimigo nº1 dos Bancos"
  description="R$ 500 milhões negociados. 11 mil processos ativos. Dr. Valdecir Rabelo, referência nacional em Direito Bancário. Reduza suas dívidas agora."
  canonicalPath="/"
  pageType="home"
  jsonLd={[organizationSchema(), websiteSchema()]}
>
  <!-- ═══ Running Ticker ═══ -->
  <div class="overflow-hidden border-b border-[rgba(201,168,108,0.10)] bg-navy-900/60 py-2.5">
    <div class="flex overflow-hidden">
      <div class="ticker-track shrink-0 select-none text-xs font-medium uppercase tracking-[0.15em] text-stone-400">
        {[
          ...ticker,
          ...ticker,
        ].map((item) => (
          <span class="inline-flex items-center gap-2 whitespace-nowrap">
            <span class="text-[10px] text-bronze-400">●</span>
            {item.label}
            <strong class="font-semibold text-cream-50">{item.value}</strong>
            <span class="text-stone-500">{item.unit}</span>
          </span>
        ))}
      </div>
    </div>
  </div>

  <!-- ═══ Hero ═══ -->
  <section class="relative overflow-hidden border-b border-[rgba(201,168,108,0.10)]">
    <!-- Background video local — zero YouTube chrome, zero postMessage, zero cookies -->
    <!-- MP4 baixado do YouTube via yt-dlp. Ver YouTubeBackground.astro para detalhes. -->
    <YouTubeBackground />

    <!-- Overlay layers -->
    <div class="absolute inset-0 bg-gradient-to-b from-navy-950/70 via-navy-950/60 to-navy-950/95 z-[1]" aria-hidden="true"></div>
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-bronze-500/15 via-transparent to-transparent z-[1]" aria-hidden="true"></div>
    <div class="absolute -top-40 left-1/2 h-[36rem] w-[36rem] -translate-x-1/2 rounded-full bg-bronze-500/5 blur-3xl z-[1]" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto grid max-w-6xl gap-12 px-5 py-24 lg:grid-cols-[1.1fr_0.9fr] lg:items-center lg:py-32">
      <div>
        <!-- Badge -->
        <p class="mb-6 inline-flex items-center gap-2 rounded-full border border-bronze-500/30 bg-bronze-500/15 px-4 py-2 text-xs font-bold uppercase tracking-[0.18em] text-bronze-400 backdrop-blur">
          <span class="h-2 w-2 animate-pulse rounded-full bg-bronze-400 shadow-[0_0_8px_rgba(201,168,108,0.6)]"></span>
          O inimigo nº1 dos bancos desde 2012
        </p>

        <!-- Headline -->
        <h1 class="max-w-3xl font-serif text-5xl font-bold tracking-tight text-cream-50 md:text-7xl lg:text-8xl">
          Seu banco <span class="text-gradient">treme</span> quando ele entra na sala.
        </h1>

        <!-- Subhead -->
        <p class="mt-7 max-w-2xl text-lg leading-8 text-stone-300">
          <strong class="text-cream-50">Dr. Valdecir Rabelo.</strong> O advogado que já arrancou <strong class="text-bronze-400">R$ 500 milhões</strong> das garras dos bancos. 
          11 mil processos ativos. 14 anos de guerra contra juros abusivos, busca e apreensão e contratos ilegais. 
          Enquanto outros prometem, ele <strong class="text-cream-50">executa</strong>.
        </p>

        <!-- CTAs -->
        <div class="mt-9 flex flex-wrap items-center gap-4">
          <LeadCtaButton cta={heroCta} pageType="home" />
          <a class="inline-flex items-center justify-center gap-2 rounded-full border border-[rgba(201,168,108,0.25)] bg-white/5 px-6 py-3 text-sm font-semibold text-cream-50 backdrop-blur transition hover:bg-white/10" href="#problemas">
            Escolher meu problema
            <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M19 9l-7 7-7-7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Valdecir Stats Card -->
      <div class="relative overflow-hidden rounded-3xl border border-bronze-500/20 bg-navy-900/70 shadow-2xl shadow-black/40 backdrop-blur glow-bronze">
        <div class="absolute -right-10 -top-10 h-40 w-40 rounded-full bg-bronze-500/10 blur-2xl" aria-hidden="true"></div>
        <div class="relative p-8">
          <div class="flex items-center justify-between">
            <p class="text-xs font-bold uppercase tracking-[0.2em] text-stone-500">Quem vai te defender</p>
            <span class="rounded-full border border-emerald-500/30 bg-emerald-500/15 px-2.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-emerald-300">Nº1 do Brasil</span>
          </div>
          <p class="mt-4 font-serif text-3xl font-bold tracking-tight text-cream-50">Dr. Valdecir Rabelo</p>
          <p class="mt-2 text-sm font-semibold uppercase tracking-[0.15em] text-bronze-400">OAB/ES 26.575 · Fundador & Presidente</p>
          <div class="mt-6 grid grid-cols-2 gap-3">
            {valdecirStats.map((stat) => (
              <div class="rounded-xl border border-[rgba(201,168,108,0.12)] bg-navy-950/60 p-4">
                <p class="text-2xl font-bold text-cream-50">{stat.value}</p>
                <p class="mt-1 text-xs text-stone-400">{stat.icon} {stat.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="ribbon-separator"></div>

  <!-- ═══ Social Proof Strip ═══ -->
  <section class="bg-warm-50 py-24">
    <div class="relative z-10 mx-auto max-w-6xl px-5 text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-warm-600">Referência nacional em Direito Bancário</p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-8 text-navy-900">
        <span class="flex items-center gap-2 text-sm text-stone-500"><span class="text-bronze-500 font-bold">+9.000</span> clientes atendidos</span>
        <span class="hidden h-4 w-px bg-[rgba(201,168,108,0.15)] sm:block" aria-hidden="true"></span>
        <span class="flex items-center gap-2 text-sm text-stone-500"><span class="text-bronze-500 font-bold">Presença</span> em todo o Brasil</span>
        <span class="hidden h-4 w-px bg-[rgba(201,168,108,0.15)] sm:block" aria-hidden="true"></span>
        <span class="flex items-center gap-2 text-sm text-stone-500"><span class="text-bronze-500 font-bold">1.075+</span> avaliações 5 estrelas</span>
        <span class="hidden h-4 w-px bg-[rgba(201,168,108,0.15)] sm:block" aria-hidden="true"></span>
        <span class="flex items-center gap-2 text-sm text-stone-500"><span class="text-bronze-500 font-bold">4</span> escritórios (RJ, SP, ES)</span>
      </div>
    </div>
  </section>

  <!-- ═══ Recado do Fundador ═══ -->
  <section class="bg-navy-mesh relative overflow-hidden py-24 lg:py-32">
    <div class="particle-overlay" aria-hidden="true"></div>

    <!-- Ambient glow orbs -->
    <div class="absolute top-1/4 left-1/4 h-64 w-64 rounded-full bg-bronze-500/8 blur-3xl" aria-hidden="true"></div>
    <div class="absolute bottom-1/3 right-1/4 h-48 w-48 rounded-full bg-gold-300/6 blur-3xl" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto max-w-6xl px-5">
      <div class="grid gap-12 lg:grid-cols-2 lg:items-center">

        <!-- Foto do Fundador com efeito dramático -->
        <div class="relative flex justify-center order-1 lg:order-1">
          <div class="founder-portrait-glow relative w-full max-w-md">
            <!-- Outer glow ring -->
            <div class="absolute -inset-3 rounded-3xl bg-gradient-to-br from-gold-300/30 via-bronze-500/15 to-bronze-600/20 blur-xl" aria-hidden="true"></div>

            <!-- Gold border frame -->
            <div class="absolute -inset-[1.5px] rounded-2xl bg-gradient-to-br from-gold-300 via-bronze-400 to-bronze-600" aria-hidden="true" style="padding:1.5px;">
              <div class="h-full w-full rounded-2xl bg-navy-950"></div>
            </div>

            <!-- Image container with vignette -->
            <div class="relative overflow-hidden rounded-2xl bg-navy-950">
              <img
                src="/assets/images/valdecir-portrait.png"
                alt="Dr. Valdecir Rabelo Filho — Fundador da VR Advogados"
                class="w-full object-cover grayscale contrast-110 brightness-90"
                loading="lazy"
              />
              <!-- Vignette overlay - darker at edges -->
              <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_40%,rgba(11,17,32,0.85)_100%)] pointer-events-none" aria-hidden="true"></div>
              <!-- Bottom fade for text -->
              <div class="absolute bottom-0 left-0 right-0 h-40 bg-gradient-to-t from-navy-950 via-navy-950/80 to-transparent pointer-events-none" aria-hidden="true"></div>
              <!-- Text overlay on image -->
              <div class="absolute bottom-0 left-0 right-0 p-6 text-center">
                <p class="font-serif text-xl font-bold text-cream-50 drop-shadow-[0_2px_8px_rgba(0,0,0,0.8)]">Dr. Valdecir Rabelo Filho</p>
                <p class="mt-1 text-sm font-semibold tracking-wide uppercase text-bronze-400 drop-shadow-[0_1px_4px_rgba(0,0,0,0.8)]">Fundador & Presidente</p>
              </div>
            </div>

            <!-- Decorative corner brackets -->
            <div class="absolute -top-3 -left-3 h-10 w-10">
              <div class="absolute top-0 left-0 h-full w-[2px] bg-gradient-to-b from-gold-300 to-transparent rounded-full"></div>
              <div class="absolute top-0 left-0 h-[2px] w-full bg-gradient-to-r from-gold-300 to-transparent rounded-full"></div>
            </div>
            <div class="absolute -top-3 -right-3 h-10 w-10">
              <div class="absolute top-0 right-0 h-full w-[2px] bg-gradient-to-b from-gold-300 to-transparent rounded-full"></div>
              <div class="absolute top-0 right-0 h-[2px] w-full bg-gradient-to-l from-gold-300 to-transparent rounded-full"></div>
            </div>
            <div class="absolute -bottom-3 -left-3 h-10 w-10">
              <div class="absolute bottom-0 left-0 h-full w-[2px] bg-gradient-to-t from-bronze-500 to-transparent rounded-full"></div>
              <div class="absolute bottom-0 left-0 h-[2px] w-full bg-gradient-to-r from-bronze-500 to-transparent rounded-full"></div>
            </div>
            <div class="absolute -bottom-3 -right-3 h-10 w-10">
              <div class="absolute bottom-0 right-0 h-full w-[2px] bg-gradient-to-t from-bronze-500 to-transparent rounded-full"></div>
              <div class="absolute bottom-0 right-0 h-[2px] w-full bg-gradient-to-l from-bronze-500 to-transparent rounded-full"></div>
            </div>
          </div>
        </div>

        <!-- Quote content -->
        <div class="order-2 lg:order-2">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-bronze-400">Um recado do fundador</p>
          <blockquote class="mt-5 font-serif text-2xl font-medium leading-relaxed tracking-tight text-cream-50 md:text-3xl">
            "Desde os meus primeiros passos no campo jurídico, tracei uma trajetória impulsionada pela paixão de enfrentar desafios complexos na esfera bancária. Em 2012, conquistei minha primeira vitória contra instituições financeiras, marcando o início de uma missão que impacta vidas."
          </blockquote>
          <div class="mt-8 flex items-start gap-4">
            <div class="flex flex-col">
              <img
                src="/assets/images/ass-valdecir.png"
                alt="Assinatura Valdecir Rabelo Filho"
                class="h-12 w-auto brightness-0 invert opacity-90"
                loading="lazy"
              />
              <p class="mt-2 text-sm font-medium text-stone-400">Valdecir Rabelo Filho — OAB/ES 26.575</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="ribbon-separator"></div>

  <!-- ═══ Áreas de atuação — Escolha por Dor ═══ -->
  <section id="problemas" class="bg-warm-dotted relative overflow-hidden py-24 lg:py-32">
    <!-- Subtle ambient glow accents -->
    <div class="absolute top-0 left-1/4 h-80 w-80 rounded-full bg-bronze-500/5 blur-3xl" aria-hidden="true"></div>
    <div class="absolute bottom-0 right-1/3 h-64 w-64 rounded-full bg-navy-900/5 blur-3xl" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto max-w-6xl px-5">
      <!-- Header block: left-aligned, stacked with drama -->
      <div class="max-w-2xl">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-bronze-500">Escolha por dor</p>
        <h2 class="mt-4 font-serif text-5xl font-bold tracking-tight text-navy-950 md:text-6xl">
          Áreas de atuação
        </h2>
        <p class="mt-5 text-lg leading-8 text-stone-500">
          Não sabe como chama o que está passando? <strong class="text-navy-950">Clique na sua dor</strong>. Cada card reúne guias, checklists e diagnóstico contextual — tudo com intenção comercial afiada.
        </p>
      </div>

      <!-- Row 1: 3 cards -->
      <div class="mt-20 grid gap-5 md:grid-cols-2 lg:grid-cols-3">
        {CLUSTERS.slice(0, 3).map((cluster) => <ClusterCard cluster={cluster} />)}
      </div>

      <!-- Row 2: 2 cards, centered (asymmetric diamond pattern 3-2) -->
      <div class="mt-5 grid gap-5 md:grid-cols-2 lg:max-w-[46rem] lg:mx-auto">
        {CLUSTERS.slice(3).map((cluster) => <ClusterCard cluster={cluster} />)}
      </div>

      <!-- CTA fallback -->
      <div class="mt-14 flex justify-center">
        <a class="group inline-flex items-center gap-2 rounded-full bg-navy-950 px-7 py-3.5 text-sm font-bold text-cream-50 shadow-lg shadow-navy-950/20 transition hover:bg-bronze-600 hover:text-navy-950 hover:shadow-bronze-500/30" href="/diagnostico-inicial/">
          Não sei qual é meu problema — me ajude
          <svg class="h-4 w-4 transition group-hover:translate-x-0.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ Como trabalhamos — Navy Dark ═══ -->
  <section class="relative overflow-hidden bg-navy-950 py-24 lg:py-32">
    <!-- Mesh overlay for depth -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,rgba(255,193,5,0.04)_1px,transparent_0)] bg-[length:40px_40px] opacity-30" aria-hidden="true"></div>
    <!-- Glow orbs -->
    <div class="absolute -top-20 right-1/4 h-72 w-72 rounded-full bg-bronze-500/6 blur-3xl" aria-hidden="true"></div>
    <div class="absolute bottom-0 left-1/3 h-64 w-64 rounded-full bg-navy-800/40 blur-3xl" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto max-w-6xl px-5">
      <div class="max-w-3xl">
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-bronze-400">Por que nos escolher</p>
        <h2 class="mt-5 font-serif text-3xl font-bold tracking-tight text-cream-50 md:text-5xl">
          Outros prometem. <span class="text-gradient">A VR executa.</span>
        </h2>
        <p class="mt-5 text-lg leading-8 text-stone-400">
          Os números você já viu acima. Aqui é onde a gente explica <strong class="text-cream-50">como</strong> — e por que só aceitamos caso que tem brecha.
        </p>
      </div>

      <!-- Pillars — numbered, side-by-side on large -->
      <div class="relative z-10 mt-14 grid gap-6 md:grid-cols-3">
        {pillars.map((pillar, idx) => (
          <div class="group relative rounded-2xl border border-[rgba(201,168,108,0.12)] bg-navy-900/60 p-7 transition hover:border-bronze-500/30 hover:bg-navy-900/80">
            <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-bronze-400/40 to-transparent opacity-0 transition group-hover:opacity-100"></div>
            <div class="flex items-baseline gap-3">
              <span class="font-serif text-3xl font-bold text-bronze-500/30">0{idx + 1}</span>
              <p class="text-xs font-bold uppercase tracking-[0.15em] text-bronze-400">{pillar.tag}</p>
            </div>
            <h3 class="mt-4 font-serif text-xl font-bold tracking-tight text-cream-50">{pillar.title}</h3>
            <p class="mt-3 text-sm leading-7 text-stone-400">{pillar.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ CTA Final ═══ -->
  <section class="bg-warm-50 py-24 lg:py-32">
    <div class="mx-auto max-w-6xl px-5">
      <div class="relative overflow-hidden rounded-[2rem] border border-[rgba(201,168,108,0.22)] bg-navy-950 p-8 md:p-14 shadow-2xl shadow-black/30">
        <div class="absolute -right-20 -top-20 h-80 w-80 rounded-full bg-bronze-500/10 blur-3xl" aria-hidden="true"></div>
        <div class="absolute -left-20 -bottom-20 h-60 w-60 rounded-full bg-gold-300/5 blur-3xl" aria-hidden="true"></div>
        <div class="relative max-w-3xl">
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-bronze-400">Último passo</p>
          <h2 class="mt-5 font-serif text-3xl font-bold tracking-tight text-cream-50 md:text-5xl">
            Ainda não tem certeza se seu caso vale a pena?
          </h2>
          <p class="mt-5 text-lg leading-8 text-stone-300">
            Faz parte. A maioria dos nossos clientes chegou sem saber se tinha brecha — e descobriu que tinha mais do que imaginava. Envie seu contrato por WhatsApp ou e-mail. Em até <strong class="text-cream-50">24h úteis</strong> nossa equipe responde com uma análise real: onde o banco errou, o que você pode recuperar e quanto isso vale. <strong class="text-cream-50">Sem consultoria paga. Sem compromisso de contratar.</strong>
          </p>
          <div class="mt-8 flex flex-wrap items-center gap-4">
            <LeadCtaButton cta={heroCta} pageType="home" />
            <a class="inline-flex items-center gap-2 rounded-full px-6 py-3 text-sm font-semibold text-bronze-400 transition hover:text-gold-300" href="/sobre-o-blog/">
              Explorar o blog
              <svg class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>