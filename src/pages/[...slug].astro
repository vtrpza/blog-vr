---
import Disclaimer from '../components/Disclaimer.astro';
import LeadCtaButton from '../components/LeadCta.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  ARTICLE_ROUTES,
  CHECKLIST_ROUTES,
  CLUSTERS,
  getArticlesByCluster,
  getClusterBySlug,
  type ArticleRoute,
  type ChecklistRoute,
  type Cluster,
  type LeadCta as LeadCtaConfig,
} from '../lib/taxonomy';
import { articleSchema, breadcrumbSchema, collectionPageSchema } from '../lib/seo';

type PageProps =
  | { kind: 'hub'; cluster: Cluster }
  | { kind: 'article'; article: ArticleRoute; cluster: Cluster }
  | { kind: 'checklist'; checklist: ChecklistRoute; cluster: Cluster };

export function getStaticPaths() {
  const hubs = CLUSTERS.map((cluster) => ({
    params: { slug: cluster.hubRoute.slice(1, -1) },
    props: { kind: 'hub' as const, cluster },
  }));

  const articles = ARTICLE_ROUTES.map((article) => ({
    params: { slug: article.slug },
    props: { kind: 'article' as const, article, cluster: getClusterBySlug(article.cluster)! },
  }));

  const checklists = CHECKLIST_ROUTES.map((checklist) => ({
    params: { slug: checklist.slug },
    props: { kind: 'checklist' as const, checklist, cluster: getClusterBySlug(checklist.cluster)! },
  }));

  return [...hubs, ...articles, ...checklists];
}

const props = Astro.props as PageProps;
const cluster = props.cluster;
const article = props.kind === 'article' ? props.article : null;
const checklist = props.kind === 'checklist' ? props.checklist : null;
const clusterArticles = getArticlesByCluster(cluster.slug);

const title = article
  ? `${article.title} | Blog VR Advogados`
  : checklist
    ? `${checklist.title} | Blog VR Advogados`
    : `${cluster.title} | Blog VR Advogados`;
const description = article
  ? `Guia informativo sobre ${article.primaryKeyword}, com resposta curta, documentos, erros comuns e próximo passo seguro.`
  : checklist
    ? `${checklist.title}: organize documentos antes de solicitar uma análise individual.`
    : cluster.summary;
const canonicalPath = article ? article.route : checklist ? checklist.route : cluster.hubRoute;
const cta: LeadCtaConfig = article
  ? { ...cluster.primaryCta, type: article.ctaType, position: 'article_after_documents' }
  : checklist
    ? checklist.cta
    : cluster.primaryCta;
const jsonLd = article
  ? [
      articleSchema(article, cluster),
      breadcrumbSchema([
        { name: 'Início', path: '/' },
        { name: cluster.shortTitle, path: cluster.hubRoute },
        { name: article.title, path: article.route },
      ]),
    ]
  : [
      collectionPageSchema(cluster),
      breadcrumbSchema([
        { name: 'Início', path: '/' },
        { name: checklist ? checklist.title : cluster.shortTitle, path: canonicalPath },
      ]),
    ];
---

<BaseLayout
  title={title}
  description={description}
  canonicalPath={canonicalPath}
  pageType={article ? 'article' : checklist ? 'checklist' : 'hub'}
  cluster={cluster.slug}
  intent={article?.intent}
  jsonLd={jsonLd}
>
  <section class="bg-white">
    <div class="mx-auto max-w-5xl px-5 py-14">
      <a class="text-sm font-bold text-blue-700 hover:text-blue-900" href={cluster.hubRoute}>← {cluster.shortTitle}</a>
      <p class="mt-6 text-xs font-black uppercase tracking-[0.25em] text-blue-700">
        {article ? 'Guia informativo' : checklist ? 'Checklist' : 'Hub de conteúdo'}
      </p>
      <h1 class="mt-3 max-w-4xl text-4xl font-black tracking-tight text-slate-950 md:text-6xl">
        {article ? article.title : checklist ? checklist.title : cluster.title}
      </h1>
      <p class="mt-6 max-w-3xl text-lg leading-8 text-slate-600">{description}</p>
      <div class="mt-8">
        <LeadCtaButton cta={cta} cluster={cluster.slug} pageType={article ? 'article' : checklist ? 'checklist' : 'hub'} intent={article?.intent} articleSlug={article?.slug} />
      </div>
    </div>
  </section>

  {article && (
    <article class="prose-vr mx-auto grid max-w-5xl gap-8 px-5 py-12 lg:grid-cols-[minmax(0,1fr)_18rem]">
      <div class="rounded-3xl bg-white p-7 shadow-sm md:p-10">
        <p class="rounded-2xl bg-blue-50 p-5 text-lg font-semibold leading-8 text-blue-950">
          Resposta curta: este tema exige comparar contrato, fase da cobrança e documentos disponíveis. O caminho seguro é organizar evidências antes de qualquer decisão.
        </p>

        <h2>Em resumo</h2>
        <p>
          Este guia explica o ponto central da busca por “{article.primaryKeyword}” e separa informação útil de promessa milagrosa. Direito bancário não se resolve com slogan; resolve com documento, prazo e estratégia.
        </p>

        <h2>Quando isso acontece</h2>
        <p>
          A situação costuma surgir quando há atraso, cobrança contestada, contrato pouco claro, pressão do banco ou dúvida sobre encargos. O detalhe muda por cluster, mas a regra operacional é a mesma: entender o contrato e preservar prova.
        </p>

        <h2>O que pode ser avaliado</h2>
        <ul>
          <li>Contrato, aditivos, taxa, CET, garantias e cláusulas de cobrança.</li>
          <li>Histórico de pagamentos, renegociações e comunicações do banco.</li>
          <li>Existência de processo, notificação, negativação ou bloqueio.</li>
          <li>Risco de urgência e melhor canal: WhatsApp, checklist ou diagnóstico.</li>
        </ul>

        <h2>Documentos necessários</h2>
        <ul>
          <li>Contrato ou número do contrato.</li>
          <li>Comprovantes, extratos e mensagens recebidas.</li>
          <li>Dados da instituição financeira e valor aproximado da dívida.</li>
          <li>Processo, mandado ou notificação, se existir.</li>
        </ul>

        <h2>Erros comuns</h2>
        <ul>
          <li>Confiar em promessa de resultado rápido.</li>
          <li>Enviar dados sensíveis sem entender finalidade e consentimento.</li>
          <li>Ignorar prazos, notificações ou movimentações processuais.</li>
        </ul>

        <h2>Próximo passo seguro</h2>
        <p>
          Organize os documentos acima e solicite uma análise inicial. O objetivo é entender cenário, urgência e possíveis caminhos — não gerar parecer automático no navegador.
        </p>

        <div class="my-8">
          <LeadCtaButton cta={cta} cluster={cluster.slug} pageType="article" intent={article.intent} articleSlug={article.slug} />
        </div>

        <h2>Perguntas frequentes</h2>
        <details class="rounded-2xl border border-slate-200 p-4">
          <summary class="cursor-pointer font-bold">Este conteúdo substitui consulta jurídica?</summary>
          <p>Não. Ele organiza informação geral; cada caso depende de documentos, valores e fase da cobrança.</p>
        </details>

        <h2>Links internos úteis</h2>
        <ul>
          {clusterArticles.filter((related) => related.slug !== article.slug).slice(0, 4).map((related) => (
            <li><a class="font-bold text-blue-700" href={related.route}>{related.title}</a></li>
          ))}
        </ul>
      </div>
      <aside class="space-y-5">
        <Disclaimer />
        <div class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
          <h2 class="text-lg font-black">Guias do hub</h2>
          <ul class="mt-4 space-y-3 text-sm font-semibold text-slate-700">
            {clusterArticles.slice(0, 6).map((item) => <li><a class="hover:text-blue-700" href={item.route}>{item.title}</a></li>)}
          </ul>
        </div>
      </aside>
    </article>
  )}

  {checklist && (
    <section class="mx-auto max-w-5xl px-5 py-12">
      <div class="rounded-3xl bg-white p-7 shadow-sm md:p-10">
        <h2 class="text-3xl font-black tracking-tight">Marque o que você já tem</h2>
        <p class="mt-3 text-slate-600">Funciona sem login. O envio para análise só deve acontecer com consentimento LGPD.</p>
        <form class="mt-8 space-y-4" data-checklist-form>
          {checklist.items.map((item) => (
            <label class="flex gap-3 rounded-2xl border border-slate-200 p-4 text-slate-700">
              <input class="mt-1 h-5 w-5" type="checkbox" name="item" value={item} />
              <span>{item}</span>
            </label>
          ))}
          <div class="pt-4">
            <LeadCtaButton cta={checklist.cta} cluster={cluster.slug} pageType="checklist" />
          </div>
        </form>
      </div>
    </section>
  )}

  {!article && !checklist && (
    <section class="mx-auto max-w-6xl px-5 py-12">
      <div class="grid gap-6 lg:grid-cols-[0.9fr_1.1fr]">
        <div class="rounded-3xl bg-white p-7 shadow-sm">
          <h2 class="text-2xl font-black tracking-tight">Comece por aqui</h2>
          <p class="mt-4 leading-8 text-slate-600">Leia primeiro os guias de maior urgência, organize documentos e use o CTA adequado para o seu problema.</p>
          <ul class="mt-6 space-y-3 text-sm text-slate-700">
            <li>✓ Resposta curta antes de enrolação.</li>
            <li>✓ Checklist de documentos.</li>
            <li>✓ CTA contextual por intenção.</li>
            <li>✓ Schema BreadcrumbList no hub.</li>
          </ul>
        </div>
        <div class="grid gap-4">
          {clusterArticles.map((item) => (
            <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
              <p class="text-xs font-black uppercase tracking-[0.2em] text-blue-700">{item.intent}</p>
              <h3 class="mt-2 text-xl font-black text-slate-950"><a href={item.route}>{item.title}</a></h3>
              <p class="mt-2 text-sm text-slate-600">Palavra principal: {item.primaryKeyword}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
